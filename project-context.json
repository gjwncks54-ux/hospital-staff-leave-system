      "displayName": "직원",
      "capabilities": [
        "own_leave_request",
        "own_history_view",
        "own_balance_view"
      ]
    },
    "LEADER": {
      "displayName": "팀장",
      "capabilities": [
        "own_leave_request",
        "own_team_history_view",
        "leader_stage_approval_only"
      ]
    },
    "HR": {
      "displayName": "인사",
      "capabilities": [
        "hr_stage_approval_only",
        "no_super_pass",
        "no_employee_management",
        "no_notice_write"
      ]
    },
    "ADMIN": {
      "displayName": "Admin",
      "capabilities": [
        "super_pass_approval",
        "employee_management",
        "notice_create_update_delete",
        "employee_leave_csv_export"
      ]
    },
    "DIRECTOR": {
      "displayName": "원장",
      "capabilities": [
        "super_pass_approval",
        "director_stage_approval",
        "employee_management",
        "notice_create_update_delete"
      ]
    }
  },
  "approvalRules": {
    "memberLeaveFlow": ["USER", "LEADER", "HR"],
    "leaderLeaveFlow": ["LEADER", "HR", "DIRECTOR"],
    "superPassRoles": ["ADMIN", "DIRECTOR"],
    "superPassBehavior": "ADMIN and DIRECTOR can approve any in-flight request immediately to the final status for that route.",
    "notes": [
      "Normal approval order is preserved for LEADER and HR.",
      "HR is not a super-pass role."
    ]
  },
  "employeeManagement": {
    "initialImport": {
      "mode": "manual_csv_handoff",
      "templateFile": "employee-import-template.csv",
      "templateColumns": [
        "employee_no",
        "name",
        "email",
        "joined_at",
        "role",
        "org_unit_name",
        "leader_employee_no",
        "is_active"
      ]
    },
    "ongoingOperations": {
      "managedInApp": true,
      "allowedRoles": ["ADMIN", "DIRECTOR"],
      "supportedActions": [
        "create_employee",
        "edit_joined_at",
        "change_org_unit",
        "change_leader",
        "deactivate_employee",
        "set_retired_at"
      ]
    },
    "csvExports": [
      {
        "name": "employee_leave_summary",
        "allowedRoles": ["ADMIN", "DIRECTOR"],
        "columns": [
          "employee_no",
          "name",
          "joined_at",
          "entitlement",
          "used",
          "remaining"
        ],
        "scope": "current filtered employee list from Admin employee tab"
      }
    ]
  },
  "features": {
    "implemented": [
      "login",
      "leave_balance_calculation",
      "leave_request_submission",
